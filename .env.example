# Telegram
BOT_TOKEN=your_bot_token_here
OWNER_ID=123456789
OWNER_USERNAME=your_username
OWNER_NAME=Your Name
OWNER_EMAIL=you@example.com
OWNER_GITHUB=your_github
OWNER_WEBSITE=https://your-site.example

# Cloudflare AI Gateway
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_AI_GATEWAY_ID=your_gateway_id
CLOUDFLARE_AI_GATEWAY_TOKEN=your_gateway_token
CLOUDFLARE_GROQ_BYOK_ALIAS=groq
CLOUDFLARE_NVIDIA_BYOK_ALIAS=nvidia

# Direct API keys (fallback if Gateway is down)
GROQ_API_KEY=your_groq_key
NVIDIA_API_KEY=your_nvidia_key
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_VIDEO_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# Cloudflare D1
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_uuid
CLOUDFLARE_D1_API_TOKEN=your_d1_api_token

# Payment (optional)
PAYMENT_UAH_CARD=
PAYMENT_UAH_BANK=Monobank
PAYMENT_USD_CARD=
PAYMENT_USD_BANK=
PAYMENT_USDT_ADDRESS=
PAYMENT_USDT_NETWORK=TRC-20

# Settings (optional, defaults shown)
MAX_TOKENS=500
MAX_FILE_MB=20
MAX_VIDEO_MB=10
MAX_DOC_MB=15
MAX_URL_MB=2
MAX_ARCHIVE_MB=8
MAX_ARCHIVE_FILES=30
MAX_TEXT_CHARS=12000
HISTORY_LIMIT=20
VIDEO_ANALYSIS_CONCURRENCY=1
